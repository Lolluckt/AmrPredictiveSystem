# Copy to ".env" and edit before running ``docker compose up``.

APP_ENV=production

# PostgreSQL (used by both the postgres container and the backend)
POSTGRES_USER=amr
POSTGRES_PASSWORD=please-change-me
POSTGRES_DB=amr_pdm

# Generate a long random value for production deployments.
JWT_SECRET=please-override-in-real-deployments

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# JWT lifetimes (minutes / days)
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
