Solid { translation 27.5 0.98 1.20 children [ USE WELDER_PANEL ] name "wp_2" }
Solid { translation 30   0.98 1.20 children [ USE WELDER_PANEL ] name "wp_3" }

# Gas cylinders — upright (default axis already Z in ENU)
DEF GAS_CYL Shape {
  appearance PBRAppearance { baseColor 0.75 0.25 0.15 roughness 0.3 metalness 0.7 }
  geometry Cylinder { height 1.3 radius 0.15 }
}
