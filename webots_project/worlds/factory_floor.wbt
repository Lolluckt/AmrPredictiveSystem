  Shape { appearance PBRAppearance { baseColor 0.18 0.18 0.22 roughness 0.4 metalness 0.6 } geometry Box { size 6.0 0.8 0.9 } }
] name "conveyor_1" boundingObject Box { size 6.0 0.8 0.9 } }

