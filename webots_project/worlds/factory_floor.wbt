] name "spark_1" }

# Fume extraction hood hanging above welders (below ceiling)
Solid { translation 27.5 1.5 2.8 children [
  Shape { appearance PBRAppearance { baseColor 0.45 0.45 0.48 roughness 0.4 metalness 0.7 } geometry Box { size 5.5 1.3 0.6 } }
] name "fume_hood" boundingObject Box { size 5.5 1.3 0.6 } }

FireExtinguisher { translation 23.5 0.5 0 name "fire_ext_1" }
FireExtinguisher { translation 31.5 7.0 0 rotation 0 0 1 3.14 name "fire_ext_2" }

# ============================================================================
# PACKAGING (x=23..32, y=11..24) — conveyor belt + boxes + pallet stacks
# ============================================================================
