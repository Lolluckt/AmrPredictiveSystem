Solid { translation 1.2 22 1.20 children [ Shape { appearance PBRAppearance { baseColor 0.06 0.06 0.10 emissiveColor 0.35 0.35 0.10 } geometry Box { size 0.6 0.05 0.4 } } ] name "qc_mon_2" }
