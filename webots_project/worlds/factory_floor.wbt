] name "cart_b2" boundingObject Box { size 1.0 0.6 0.7 } }

# ============================================================================
# WELDING (x=23..32, y=0..9) — 3 welder cabinets + gas cylinders + sparks
# ============================================================================
DEF WELDER Shape { appearance PBRAppearance { baseColor 0.22 0.22 0.26 roughness 0.3 metalness 0.75 } geometry Box { size 1.4 1.0 1.4 } }
Solid { translation 25   1.5 0.7 children [ USE WELDER ] name "welder_1" boundingObject Box { size 1.4 1.0 1.4 } }
Solid { translation 27.5 1.5 0.7 children [ USE WELDER ] name "welder_2" boundingObject Box { size 1.4 1.0 1.4 } }
Solid { translation 30   1.5 0.7 children [ USE WELDER ] name "welder_3" boundingObject Box { size 1.4 1.0 1.4 } }

# Welder control panels (small box with LCD emissive)
DEF WELDER_PANEL Shape { appearance PBRAppearance { baseColor 0.08 0.08 0.10 emissiveColor 0.25 0.10 0.05 } geometry Box { size 0.3 0.05 0.18 } }
