  Pose { translation 0.25 0 0.5 children [ Shape { appearance PBRAppearance { baseColor 0.10 0.10 0.15 emissiveColor 0.15 0.30 0.08 } geometry Box { size 0.05 0.6 0.3 } } ] }
] name "elec_cabinet" boundingObject Box { size 0.4 2.0 1.8 } }

# Dock markers at y=13 (where robots drive in to align)
DEF DOCK_MARKER Shape { appearance PBRAppearance { baseColor 0.25 0.85 0.35 emissiveColor 0.1 0.5 0.15 roughness 0.5 } geometry Box { size 0.7 0.7 0.004 } }
Solid { translation 2 13 0.008 children [ USE DOCK_MARKER ] name "dock_cs01" }
Solid { translation 5 13 0.008 children [ USE DOCK_MARKER ] name "dock_cs02" }
Solid { translation 8 13 0.008 children [ USE DOCK_MARKER ] name "dock_cs03" }

