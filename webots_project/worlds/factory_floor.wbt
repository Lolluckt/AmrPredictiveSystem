Hammer  { translation 21.2 1.30 0.92 rotation 0 0 1 -0.3 name "hammer_a" }

# Cabinet against east wall
Solid { translation 22.7 5 0.9 children [ Shape { appearance PBRAppearance { baseColor 0.55 0.55 0.60 roughness 0.5 metalness 0.4 } geometry Box { size 0.5 3.0 1.8 } } ] name "cab_a1" boundingObject Box { size 0.5 3.0 1.8 } }

# ============================================================================
