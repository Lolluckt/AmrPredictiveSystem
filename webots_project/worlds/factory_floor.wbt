Solid { translation 20 18 3.2 children [ Shape { appearance PBRAppearance { baseColor 0.80 0.80 0.82 roughness 0.35 metalness 0.75 } geometry Box { size 39.6 0.5 0.4 } } ] name "vent_n" }

