Solid { translation 5  18    0.009 children [ USE PICKUP_MARKER ] name "pickup_qc" }
Solid { translation 18  9    0.009 children [ USE DROPOFF_MARKER ] name "dropoff_a" }
Solid { translation 18 11    0.009 children [ USE DROPOFF_MARKER ] name "dropoff_b" }
Solid { translation 27.5 9   0.009 children [ USE DROPOFF_MARKER ] name "dropoff_w" }
Solid { translation 27.5 14  0.009 children [ USE DROPOFF_MARKER ] name "dropoff_pkg" }
Solid { translation 34  6    0.009 children [ USE DROPOFF_MARKER ] name "dropoff_fin_a" }
Solid { translation 34 16    0.009 children [ USE DROPOFF_MARKER ] name "dropoff_fin_b" }

# ============================================================================
