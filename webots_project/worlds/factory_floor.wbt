] name "qc_cabinet" boundingObject Box { size 0.4 0.8 1.6 } }

# ============================================================================
# SAFETY EQUIPMENT — fire extinguishers in corners, bollards at intersections
# ============================================================================
FireExtinguisher { translation 0.5 0.5  0 rotation 0 0 1 0.5 name "fire_ext_3" }
FireExtinguisher { translation 0.5 23.5 0 rotation 0 0 1 0.3 name "fire_ext_4" }
FireExtinguisher { translation 39.5 0.5  0 rotation 0 0 1 -0.5 name "fire_ext_5" }
FireExtinguisher { translation 39.5 23.5 0 rotation 0 0 1 -0.3 name "fire_ext_6" }

# Yellow safety bollards — upright cylinders (default axis = Z in ENU)
DEF BOLLARD Shape {
  appearance PBRAppearance { baseColor 0.95 0.80 0.12 roughness 0.4 }
  geometry Cylinder { height 0.9 radius 0.07 }
}
Solid { translation  9.8  8.7 0.45 children [ USE BOLLARD ] name "boll_1" boundingObject Cylinder { height 0.9 radius 0.07 } }
Solid { translation 13.2  8.7 0.45 children [ USE BOLLARD ] name "boll_2" boundingObject Cylinder { height 0.9 radius 0.07 } }
Solid { translation  9.8 11.3 0.45 children [ USE BOLLARD ] name "boll_3" boundingObject Cylinder { height 0.9 radius 0.07 } }
Solid { translation 13.2 11.3 0.45 children [ USE BOLLARD ] name "boll_4" boundingObject Cylinder { height 0.9 radius 0.07 } }

# Safety cones near welding zone
DEF CONE Shape {
  appearance PBRAppearance { baseColor 0.95 0.45 0.10 roughness 0.5 }
  geometry Cylinder { height 0.4 radius 0.11 }
}
Solid { translation 23.5 4 0.20 children [ USE CONE ] name "cone_1" boundingObject Cylinder { height 0.4 radius 0.11 } }
Solid { translation 23.5 6 0.20 children [ USE CONE ] name "cone_2" boundingObject Cylinder { height 0.4 radius 0.11 } }

# HMI panels mounted on walls
DEF HMI Shape { appearance PBRAppearance { baseColor 0.05 0.08 0.15 emissiveColor 0.10 0.35 0.55 } geometry Box { size 0.9 0.06 0.6 } }
Solid { translation 11.5  0.03 1.7 children [ USE HMI ] name "hmi_s" boundingObject Box { size 0.9 0.06 0.6 } }
Solid { translation 11.5 23.97 1.7 children [ USE HMI ] name "hmi_n" boundingObject Box { size 0.9 0.06 0.6 } }
Solid { translation 39.97 12 1.7 children [ USE HMI ] name "hmi_e" boundingObject Box { size 0.06 0.9 0.6 } }

# Warning signs on walls (red squares)
DEF SIGN_RED Shape { appearance PBRAppearance { baseColor 0.85 0.15 0.15 emissiveColor 0.3 0.05 0.05 } geometry Box { size 0.4 0.02 0.4 } }
Solid { translation 24 0.04 2.2 children [ USE SIGN_RED ] name "sign_weld" }
Solid { translation 11.5 0.04 2.6 children [ USE SIGN_RED ] name "sign_corr" }

# ============================================================================
# ROBOTS — 3 differential-drive AMRs (ENU-correct geometry)
#
# Layout inside Robot frame (robot faces +X):
#   • Chassis: Box (0.30 × 0.28 × 0.08) at z=0.10  → bottom 0.06, top 0.14
#   • Top ring: upright cylinder at z=0.15          → bottom 0.14, top 0.16
#   • Sensor dome: upright cylinder at z=0.175      → bottom 0.16, top 0.19
#   • Wheels: cylinders axis=Y (default) at (0, ±0.14, 0.06), radius 0.06
#     → bottom at z=0 (on floor), top at z=0.12
#   • Casters: spheres at (±0.10, 0, 0.025), radius 0.025 → bottom z=0
#   • Front LED: small red/blue/green box at (0.15, 0, 0.10)
#   • Lidar: at (0, 0, 0.20) on top of sensor dome
#   • Sonars: 8 around perimeter at z=0.10 (chassis mid-height)
#
# Wheel axis = joint axis = Y.  Default cylinder axis is Y, so no rotation
# needed on the wheel cylinder — it naturally looks like a proper wheel.
# ============================================================================

# ---- AMR-01 (BLUE) — Warehouse raw ↔ Assembly A/B ----
Robot {
  translation 5 4.5 0.005
  rotation 0 0 1 0
  name "AMR-01"
  controller "amr_controller"
  customData "amr_01"
  children [
    # Chassis — solid dark-grey box
    Pose { translation 0 0 0.10 children [
      Shape { appearance PBRAppearance { baseColor 0.10 0.10 0.12 roughness 0.35 metalness 0.55 } geometry Box { size 0.30 0.28 0.08 } }
    ] }
    # Color top ring (blue)
    Pose { translation 0 0 0.15 children [
      Shape { appearance PBRAppearance { baseColor 0.20 0.45 0.85 roughness 0.3 metalness 0.2 } geometry Cylinder { height 0.02 radius 0.14 } }
    ] }
    # Sensor dome (dark grey short cylinder)
    Pose { translation 0 0 0.175 children [
      Shape { appearance PBRAppearance { baseColor 0.14 0.14 0.17 roughness 0.25 metalness 0.6 } geometry Cylinder { height 0.03 radius 0.05 } }
    ] }
    # Front LED (heading indicator)
    Pose { translation 0.15 0 0.10 children [
      Shape { appearance PBRAppearance { baseColor 0.30 0.55 0.95 emissiveColor 0.25 0.45 0.85 } geometry Box { size 0.015 0.10 0.02 } }
    ] }
    # Side numbering plaque
    Pose { translation 0 0.145 0.10 children [
      Shape { appearance PBRAppearance { baseColor 0.95 0.95 0.95 emissiveColor 0.4 0.4 0.4 } geometry Box { size 0.08 0.003 0.04 } }
    ] }
    # LEFT WHEEL — anchor at (0, +0.14, 0.06), axle along Y
    HingeJoint {
      jointParameters HingeJointParameters { anchor 0 0.14 0.06 axis 0 1 0 }
      device [
        RotationalMotor { name "left wheel motor" maxVelocity 18 maxTorque 8 }
        PositionSensor { name "left wheel sensor" }
      ]
      endPoint Solid {
        translation 0 0.14 0.06
        children [
          Pose { rotation 1 0 0 1.5708 children [
            Shape { appearance PBRAppearance { baseColor 0.05 0.05 0.05 roughness 0.95 } geometry Cylinder { height 0.03 radius 0.06 } }
          ] }
        ]
        name "left wheel"
        boundingObject Pose { rotation 1 0 0 1.5708 children [ Cylinder { height 0.03 radius 0.06 } ] }
        physics Physics { density -1 mass 0.3 }
        contactMaterial "wheel"
      }
    }
    # RIGHT WHEEL
    HingeJoint {
      jointParameters HingeJointParameters { anchor 0 -0.14 0.06 axis 0 1 0 }
      device [
        RotationalMotor { name "right wheel motor" maxVelocity 18 maxTorque 8 }
        PositionSensor { name "right wheel sensor" }
      ]
      endPoint Solid {
        translation 0 -0.14 0.06
        children [
          Pose { rotation 1 0 0 1.5708 children [
            Shape { appearance PBRAppearance { baseColor 0.05 0.05 0.05 roughness 0.95 } geometry Cylinder { height 0.03 radius 0.06 } }
          ] }
        ]
        name "right wheel"
        boundingObject Pose { rotation 1 0 0 1.5708 children [ Cylinder { height 0.03 radius 0.06 } ] }
        physics Physics { density -1 mass 0.3 }
        contactMaterial "wheel"
      }
    }
    # Front + rear casters (spheres)
    Solid { translation 0.10 0 0.025 children [
      Shape { appearance PBRAppearance { baseColor 0.12 0.12 0.12 roughness 0.4 } geometry Sphere { radius 0.025 } }
    ] name "caster_f" boundingObject Sphere { radius 0.025 } physics Physics { density -1 mass 0.05 } contactMaterial "wheel" }
    Solid { translation -0.10 0 0.025 children [
      Shape { appearance PBRAppearance { baseColor 0.12 0.12 0.12 roughness 0.4 } geometry Sphere { radius 0.025 } }
    ] name "caster_r" boundingObject Sphere { radius 0.025 } physics Physics { density -1 mass 0.05 } contactMaterial "wheel" }
    # Navigation sensors
    GPS         { name "gps" }
    Compass     { name "compass" }
    InertialUnit { name "imu" }
    Accelerometer { name "accelerometer" }
    Gyro        { name "gyro" }
    # 360° LiDAR on top of sensor dome
    Lidar {
      translation 0 0 0.22
      name "lidar"
      horizontalResolution 32
      fieldOfView 6.2831
      verticalFieldOfView 0.05
      numberOfLayers 1
      minRange 0.08
      maxRange 5.0
      noise 0.005
    }
    # 8-way sonar ring at chassis mid-height
    DistanceSensor { translation  0.15  0     0.10 rotation 0 0 1  0       name "ds_0"   lookupTable [0 0 0, 3 3000 0] type "sonar" }
    DistanceSensor { translation  0.106 0.106 0.10 rotation 0 0 1  0.7854  name "ds_45"  lookupTable [0 0 0, 3 3000 0] type "sonar" }
    DistanceSensor { translation  0     0.15  0.10 rotation 0 0 1  1.5708  name "ds_90"  lookupTable [0 0 0, 2 2000 0] type "sonar" }
    DistanceSensor { translation -0.106 0.106 0.10 rotation 0 0 1  2.3562  name "ds_135" lookupTable [0 0 0, 2 2000 0] type "sonar" }
    DistanceSensor { translation -0.15  0     0.10 rotation 0 0 1  3.1416  name "ds_180" lookupTable [0 0 0, 2 2000 0] type "sonar" }
    DistanceSensor { translation -0.106 -0.106 0.10 rotation 0 0 1 -2.3562 name "ds_225" lookupTable [0 0 0, 2 2000 0] type "sonar" }
    DistanceSensor { translation  0    -0.15  0.10 rotation 0 0 1 -1.5708  name "ds_270" lookupTable [0 0 0, 2 2000 0] type "sonar" }
    DistanceSensor { translation  0.106 -0.106 0.10 rotation 0 0 1 -0.7854 name "ds_315" lookupTable [0 0 0, 3 3000 0] type "sonar" }
    LED { name "status_led" color [ 0 1 0, 1 1 0, 1 0 0, 0 0 1 ] }
  ]
  boundingObject Pose { translation 0 0 0.10 children [ Box { size 0.30 0.28 0.08 } ] }
  physics Physics { density -1 mass 12 centerOfMass [ 0 0 0.06 ] }
}

# ---- AMR-02 (ORANGE) — Assembly A → Welding → Packaging → Finished ----
Robot {
  translation 18 4.5 0.005
  rotation 0 0 1 1.5708
  name "AMR-02"
  controller "amr_controller"
  customData "amr_02"
  children [
    Pose { translation 0 0 0.10 children [
      Shape { appearance PBRAppearance { baseColor 0.10 0.10 0.12 roughness 0.35 metalness 0.55 } geometry Box { size 0.30 0.28 0.08 } }
    ] }
    Pose { translation 0 0 0.15 children [
      Shape { appearance PBRAppearance { baseColor 0.88 0.42 0.12 roughness 0.3 metalness 0.2 } geometry Cylinder { height 0.02 radius 0.14 } }
    ] }
    Pose { translation 0 0 0.175 children [
      Shape { appearance PBRAppearance { baseColor 0.14 0.14 0.17 roughness 0.25 metalness 0.6 } geometry Cylinder { height 0.03 radius 0.05 } }
    ] }
    Pose { translation 0.15 0 0.10 children [
      Shape { appearance PBRAppearance { baseColor 0.95 0.55 0.15 emissiveColor 0.65 0.35 0.05 } geometry Box { size 0.015 0.10 0.02 } }
    ] }
    Pose { translation 0 0.145 0.10 children [
      Shape { appearance PBRAppearance { baseColor 0.95 0.95 0.95 emissiveColor 0.4 0.4 0.4 } geometry Box { size 0.08 0.003 0.04 } }
    ] }
    HingeJoint {
      jointParameters HingeJointParameters { anchor 0 0.14 0.06 axis 0 1 0 }
      device [ RotationalMotor { name "left wheel motor" maxVelocity 18 maxTorque 8 } PositionSensor { name "left wheel sensor" } ]
      endPoint Solid { translation 0 0.14 0.06 children [ Pose { rotation 1 0 0 1.5708 children [ Shape { appearance PBRAppearance { baseColor 0.05 0.05 0.05 roughness 0.95 } geometry Cylinder { height 0.03 radius 0.06 } } ] } ] name "left wheel" boundingObject Pose { rotation 1 0 0 1.5708 children [ Cylinder { height 0.03 radius 0.06 } ] } physics Physics { density -1 mass 0.3 } contactMaterial "wheel" }
    }
    HingeJoint {
      jointParameters HingeJointParameters { anchor 0 -0.14 0.06 axis 0 1 0 }
      device [ RotationalMotor { name "right wheel motor" maxVelocity 18 maxTorque 8 } PositionSensor { name "right wheel sensor" } ]
      endPoint Solid { translation 0 -0.14 0.06 children [ Pose { rotation 1 0 0 1.5708 children [ Shape { appearance PBRAppearance { baseColor 0.05 0.05 0.05 roughness 0.95 } geometry Cylinder { height 0.03 radius 0.06 } } ] } ] name "right wheel" boundingObject Pose { rotation 1 0 0 1.5708 children [ Cylinder { height 0.03 radius 0.06 } ] } physics Physics { density -1 mass 0.3 } contactMaterial "wheel" }
    }
    Solid { translation  0.10 0 0.025 children [ Shape { appearance PBRAppearance { baseColor 0.12 0.12 0.12 roughness 0.4 } geometry Sphere { radius 0.025 } } ] name "caster_f" boundingObject Sphere { radius 0.025 } physics Physics { density -1 mass 0.05 } contactMaterial "wheel" }
    Solid { translation -0.10 0 0.025 children [ Shape { appearance PBRAppearance { baseColor 0.12 0.12 0.12 roughness 0.4 } geometry Sphere { radius 0.025 } } ] name "caster_r" boundingObject Sphere { radius 0.025 } physics Physics { density -1 mass 0.05 } contactMaterial "wheel" }
    GPS { name "gps" } Compass { name "compass" } InertialUnit { name "imu" } Accelerometer { name "accelerometer" } Gyro { name "gyro" }
    Lidar { translation 0 0 0.22 name "lidar" horizontalResolution 32 fieldOfView 6.2831 verticalFieldOfView 0.05 numberOfLayers 1 minRange 0.08 maxRange 5.0 noise 0.005 }
    DistanceSensor { translation  0.15  0     0.10 rotation 0 0 1  0       name "ds_0"   lookupTable [0 0 0, 3 3000 0] type "sonar" }
    DistanceSensor { translation  0.106 0.106 0.10 rotation 0 0 1  0.7854  name "ds_45"  lookupTable [0 0 0, 3 3000 0] type "sonar" }
    DistanceSensor { translation  0     0.15  0.10 rotation 0 0 1  1.5708  name "ds_90"  lookupTable [0 0 0, 2 2000 0] type "sonar" }
    DistanceSensor { translation -0.106 0.106 0.10 rotation 0 0 1  2.3562  name "ds_135" lookupTable [0 0 0, 2 2000 0] type "sonar" }
    DistanceSensor { translation -0.15  0     0.10 rotation 0 0 1  3.1416  name "ds_180" lookupTable [0 0 0, 2 2000 0] type "sonar" }
    DistanceSensor { translation -0.106 -0.106 0.10 rotation 0 0 1 -2.3562 name "ds_225" lookupTable [0 0 0, 2 2000 0] type "sonar" }
    DistanceSensor { translation  0    -0.15  0.10 rotation 0 0 1 -1.5708  name "ds_270" lookupTable [0 0 0, 2 2000 0] type "sonar" }
    DistanceSensor { translation  0.106 -0.106 0.10 rotation 0 0 1 -0.7854 name "ds_315" lookupTable [0 0 0, 3 3000 0] type "sonar" }
    LED { name "status_led" color [ 0 1 0, 1 1 0, 1 0 0, 0 0 1 ] }
  ]
  boundingObject Pose { translation 0 0 0.10 children [ Box { size 0.30 0.28 0.08 } ] }
  physics Physics { density -1 mass 12 centerOfMass [ 0 0 0.06 ] }
}

