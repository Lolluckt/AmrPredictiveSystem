CardboardBox { translation 37.5 18 0.20 name "fb_2" size 0.5 0.5 0.4 }

# Forklift (simplified) parked at south end
Solid { translation 34.5 2.5 0.35 children [
  Shape { appearance PBRAppearance { baseColor 0.95 0.65 0.10 roughness 0.4 metalness 0.3 } geometry Box { size 1.2 0.9 0.7 } }
  Pose { translation -0.1 0 0.80 children [ Shape { appearance PBRAppearance { baseColor 0.20 0.20 0.22 roughness 0.4 } geometry Box { size 0.9 0.8 0.9 } } ] }
  Pose { translation 0.55 0 0.25 children [ Shape { appearance PBRAppearance { baseColor 0.45 0.45 0.45 roughness 0.3 metalness 0.8 } geometry Box { size 0.1 0.6 1.8 } } ] }
] name "forklift" boundingObject Box { size 1.2 0.9 0.7 } }

# ============================================================================
# CHARGING STATIONS (x=0..10, y=11..15) — 3 stations aligned at y=11.5
# ============================================================================
DEF CHARGER Shape {
  appearance PBRAppearance { baseColor 0.18 0.55 0.30 roughness 0.3 metalness 0.4 }
  geometry Box { size 0.60 0.50 0.40 }
}
DEF CHARGER_POLE Shape {
  appearance PBRAppearance { baseColor 0.25 0.60 0.35 roughness 0.4 metalness 0.4 }
  geometry Box { size 0.14 0.14 0.9 }
}
DEF CHARGER_LED Shape {
  appearance PBRAppearance { baseColor 0.15 0.95 0.25 emissiveColor 0.1 0.8 0.15 }
  geometry Sphere { radius 0.07 }
}
Solid {
  translation 2 11.5 0.2
  children [
    USE CHARGER
    Pose { translation 0 -0.05 0.65 children [ USE CHARGER_POLE ] }
    Pose { translation 0 -0.05 1.20 children [ USE CHARGER_LED ] }
  ]
  name "CS01" boundingObject Box { size 0.60 0.50 0.40 }
}
Solid {
  translation 5 11.5 0.2
  children [
    USE CHARGER
    Pose { translation 0 -0.05 0.65 children [ USE CHARGER_POLE ] }
    Pose { translation 0 -0.05 1.20 children [ USE CHARGER_LED ] }
  ]
  name "CS02" boundingObject Box { size 0.60 0.50 0.40 }
}
Solid {
  translation 8 11.5 0.2
  children [
    USE CHARGER
    Pose { translation 0 -0.05 0.65 children [ USE CHARGER_POLE ] }
    Pose { translation 0 -0.05 1.20 children [ USE CHARGER_LED ] }
  ]
  name "CS03" boundingObject Box { size 0.60 0.50 0.40 }
}

# Electrical cabinet behind chargers
Solid { translation 0.5 12 0.90 children [
