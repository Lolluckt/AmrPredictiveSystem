Solid { translation 1.0 4.5 1.1 children [ USE RACK_SHAPE ] name "rack_raw_2" boundingObject Box { size 1.6 0.6 2.2 } }
Solid { translation 1.0 7.5 1.1 children [ USE RACK_SHAPE ] name "rack_raw_3" boundingObject Box { size 1.6 0.6 2.2 } }
