Solid { translation 15 22.5 0.45 children [ USE WORKBENCH ] name "table_b1" boundingObject Box { size 1.8 1.0 0.9 } }
Solid { translation 18 22.5 0.45 children [ USE WORKBENCH ] name "table_b2" boundingObject Box { size 1.8 1.0 0.9 } }
