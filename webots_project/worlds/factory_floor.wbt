#VRML_SIM R2025a utf8
# ============================================================================
# Factory Floor — AMR Predictive Maintenance Digital Twin
#
# 40 × 24 m production hall with 9 functional zones and 3 differential-drive
# AMRs.  All geometry positions assume ENU (Z-up) — explicitly set below.
#
# Conventions (per Webots Reference Manual):
#   • Box size = (dx, dy, dz); z is vertical, so an object sits on the floor
#     when translation.z == dz/2.
#   • In `coordinateSystem "ENU"`, a Cylinder's default symmetry axis is Z
#     (vertical). Upright cylinders (bollards, domes, gas bottles) therefore
#     need NO rotation.  Horizontal cylinders (wheels, conveyor rollers) are
#     rotated with `rotation 1 0 0 1.5708`, which maps Z → -Y so their axis
#     becomes horizontal along the Y axis.
# ============================================================================

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/factory/containers/protos/WoodenBox.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/factory/containers/protos/CardboardBox.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/factory/pallet/protos/WoodenPallet.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/factory/fire_extinguisher/protos/FireExtinguisher.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/factory/tools/protos/Wrench.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/factory/tools/protos/Hammer.proto"

WorldInfo {
  title "Factory Floor — AMR Predictive Maintenance"
  basicTimeStep 16
  coordinateSystem "ENU"
  contactProperties [
    ContactProperties {
      material1 "floor"
      material2 "wheel"
      coulombFriction [ 0.9 ]
      softCFM 0.0001
      bounce 0
    }
  ]
}
Viewpoint {
  orientation -0.18 0.06 0.98 3.48
  position 38 -8 22
}
TexturedBackground { texture "factory" }
TexturedBackgroundLight { texture "factory" luminosity 1.2 }

# ============================================================================
# LIGHTING — ceiling fixtures mounted just below the 4 m wall height
# ============================================================================
PointLight { attenuation 0 0 0.0035 intensity 6 location 10  6 3.8  castShadows TRUE }
PointLight { attenuation 0 0 0.0035 intensity 6 location 30  6 3.8  castShadows TRUE }
PointLight { attenuation 0 0 0.0035 intensity 6 location 10 18 3.8  castShadows TRUE }
PointLight { attenuation 0 0 0.0035 intensity 6 location 30 18 3.8  castShadows TRUE }
PointLight { attenuation 0 0 0.005  intensity 3 location 20 12 3.8 }

# Visible lamp housings (dark plates with emissive underside) at z=3.8
DEF LAMP_SHAPE Shape {
  appearance PBRAppearance { baseColor 0.12 0.12 0.12 emissiveColor 0.85 0.85 0.7 roughness 0.3 }
  geometry Box { size 1.0 0.25 0.05 }
}
Solid { translation 10 6  3.8 children [ USE LAMP_SHAPE ] name "lamp_1" }
Solid { translation 30 6  3.8 children [ USE LAMP_SHAPE ] name "lamp_2" }
Solid { translation 10 18 3.8 children [ USE LAMP_SHAPE ] name "lamp_3" }
Solid { translation 30 18 3.8 children [ USE LAMP_SHAPE ] name "lamp_4" }
Solid { translation 20 12 3.8 children [ USE LAMP_SHAPE ] name "lamp_5" }

# ============================================================================
# FLOOR + WALLS — 40 × 24 m polished concrete arena, 4 m walls
# ============================================================================
RectangleArena {
  translation 20 12 0
  floorSize 40 24
  floorTileSize 2 2
  floorAppearance PBRAppearance {
    baseColor 0.72 0.72 0.70
    roughness 0.75
    metalness 0.02
  }
  wallHeight 4.0
  wallAppearance PBRAppearance {
    baseColor 0.78 0.78 0.76
    roughness 0.85
    metalness 0.02
  }
}

# ============================================================================
# ZONE OVERLAYS — colored floor patches at z = 0.003 (just above floor).
# No physics, no boundingObject — robots pass freely.
# Layout:
#   x=0..10  Warehouse-raw (y=0..9) | Charging (y=11..15) | QC (y=15..24)
#   x=10..13 Main NS corridor (3 m wide)
#   x=13..23 Assembly-A (y=0..9) | Assembly-B (y=11..24)
#   x=23..32 Welding (y=0..9)    | Packaging (y=11..24)
#   x=32..40 Finished warehouse (all y)
#   y=9..11  East-West corridor (2 m wide) spans the full hall
# ============================================================================
Solid { translation 5    4.5  0.003 children [ Shape { appearance PBRAppearance { baseColor 0.32 0.42 0.72 roughness 0.9 transparency 0.38 } geometry Box { size 9.6 8.4 0.005 } } ] name "zone_warehouse_raw" }
Solid { translation 11.5 12   0.003 children [ Shape { appearance PBRAppearance { baseColor 0.55 0.55 0.55 roughness 0.9 transparency 0.45 } geometry Box { size 2.8 23.6 0.005 } } ] name "zone_corridor_main" }
Solid { translation 18   4.5  0.003 children [ Shape { appearance PBRAppearance { baseColor 0.18 0.58 0.28 roughness 0.9 transparency 0.38 } geometry Box { size 9.6 8.4 0.005 } } ] name "zone_assembly_a" }
Solid { translation 20  10    0.003 children [ Shape { appearance PBRAppearance { baseColor 0.55 0.55 0.55 roughness 0.9 transparency 0.45 } geometry Box { size 39.6 1.8 0.005 } } ] name "zone_corridor_mid" }
Solid { translation 18  17.5  0.003 children [ Shape { appearance PBRAppearance { baseColor 0.18 0.55 0.28 roughness 0.9 transparency 0.38 } geometry Box { size 9.6 12.6 0.005 } } ] name "zone_assembly_b" }
Solid { translation 27.5 4.5  0.003 children [ Shape { appearance PBRAppearance { baseColor 0.78 0.62 0.12 roughness 0.9 transparency 0.38 } geometry Box { size 8.6 8.4 0.005 } } ] name "zone_welding" }
Solid { translation 27.5 17.5 0.003 children [ Shape { appearance PBRAppearance { baseColor 0.65 0.22 0.45 roughness 0.9 transparency 0.38 } geometry Box { size 8.6 12.6 0.005 } } ] name "zone_packaging" }
Solid { translation 5   13    0.003 children [ Shape { appearance PBRAppearance { baseColor 0.18 0.55 0.80 roughness 0.9 transparency 0.38 } geometry Box { size 9.6 3.6 0.005 } } ] name "zone_charging" }
Solid { translation 5   19.5  0.003 children [ Shape { appearance PBRAppearance { baseColor 0.48 0.25 0.65 roughness 0.9 transparency 0.38 } geometry Box { size 9.6 8.4 0.005 } } ] name "zone_quality_control" }
Solid { translation 36  12    0.003 children [ Shape { appearance PBRAppearance { baseColor 0.32 0.32 0.68 roughness 0.9 transparency 0.38 } geometry Box { size 7.6 23.6 0.005 } } ] name "zone_warehouse_finished" }

# ============================================================================
# FLOOR SAFETY LINES (yellow) — along corridor edges
# ============================================================================
Solid { translation 10 12 0.006 children [ Shape { appearance PBRAppearance { baseColor 0.95 0.80 0.15 roughness 0.4 } geometry Box { size 0.08 23.6 0.004 } } ] name "line_corr_w" }
Solid { translation 13 12 0.006 children [ Shape { appearance PBRAppearance { baseColor 0.95 0.80 0.15 roughness 0.4 } geometry Box { size 0.08 23.6 0.004 } } ] name "line_corr_e" }
Solid { translation 20  9 0.006 children [ Shape { appearance PBRAppearance { baseColor 0.95 0.80 0.15 roughness 0.4 } geometry Box { size 39.6 0.08 0.004 } } ] name "line_mid_s" }
Solid { translation 20 11 0.006 children [ Shape { appearance PBRAppearance { baseColor 0.95 0.80 0.15 roughness 0.4 } geometry Box { size 39.6 0.08 0.004 } } ] name "line_mid_n" }

# Pedestrian crosswalk stripes at corridor intersections
DEF CROSSWALK_STRIPE Shape { appearance PBRAppearance { baseColor 0.92 0.92 0.88 roughness 0.5 } geometry Box { size 0.3 1.5 0.003 } }
Solid { translation 11.2 10 0.007 children [ USE CROSSWALK_STRIPE ] name "cw_1" }
Solid { translation 11.8 10 0.007 children [ USE CROSSWALK_STRIPE ] name "cw_2" }
Solid { translation 12.4 10 0.007 children [ USE CROSSWALK_STRIPE ] name "cw_3" }

# Waypoint marker dots (blue) for visual alignment with controller waypoints
DEF WP_MARKER Shape { appearance PBRAppearance { baseColor 0.22 0.45 0.95 emissiveColor 0.1 0.25 0.6 roughness 0.4 } geometry Box { size 0.55 0.55 0.004 } }
Solid { translation 11.5  4.5 0.008 children [ USE WP_MARKER ] name "wp_s" }
Solid { translation 11.5 10   0.008 children [ USE WP_MARKER ] name "wp_ms" }
Solid { translation 11.5 17.5 0.008 children [ USE WP_MARKER ] name "wp_n" }
Solid { translation 18   10   0.008 children [ USE WP_MARKER ] name "wp_a" }
Solid { translation 27.5 10   0.008 children [ USE WP_MARKER ] name "wp_w" }
Solid { translation 34   10   0.008 children [ USE WP_MARKER ] name "wp_f" }

# Pick-up / drop-off markers (orange = pickup, green = dropoff)
DEF PICKUP_MARKER Shape { appearance PBRAppearance { baseColor 0.95 0.55 0.15 emissiveColor 0.5 0.25 0.05 roughness 0.5 } geometry Box { size 0.8 0.8 0.004 } }
DEF DROPOFF_MARKER Shape { appearance PBRAppearance { baseColor 0.22 0.82 0.30 emissiveColor 0.1 0.45 0.15 roughness 0.5 } geometry Box { size 0.8 0.8 0.004 } }
