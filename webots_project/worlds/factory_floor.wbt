CardboardBox { translation 7.4 3.0 0.18 name "cbox_r2" size 0.5 0.5 0.3 }

# Pallet jack (decorative box + small handle)
Solid { translation 4.5 6.2 0.10 children [
  Shape { appearance PBRAppearance { baseColor 0.85 0.60 0.15 roughness 0.4 metalness 0.3 } geometry Box { size 0.9 0.5 0.2 } }
  Pose { translation -0.3 0 0.5 children [ Shape { appearance PBRAppearance { baseColor 0.15 0.15 0.15 roughness 0.4 } geometry Box { size 0.08 0.08 1.0 } } ] }
] name "pallet_jack_1" boundingObject Box { size 0.9 0.5 0.2 } }

# ============================================================================
# ASSEMBLY A (x=13..23, y=0..9) — 3 workbenches along north wall y=2
# ============================================================================
DEF WORKBENCH Shape { appearance PBRAppearance { baseColor 0.55 0.50 0.44 roughness 0.4 metalness 0.1 } geometry Box { size 1.8 1.0 0.9 } }
Solid { translation 15 1.5 0.45 children [ USE WORKBENCH ] name "table_a1" boundingObject Box { size 1.8 1.0 0.9 } }
Solid { translation 18 1.5 0.45 children [ USE WORKBENCH ] name "table_a2" boundingObject Box { size 1.8 1.0 0.9 } }
Solid { translation 21 1.5 0.45 children [ USE WORKBENCH ] name "table_a3" boundingObject Box { size 1.8 1.0 0.9 } }

# Monitors on workbenches (simulated)
DEF MONITOR Shape { appearance PBRAppearance { baseColor 0.08 0.08 0.12 emissiveColor 0.1 0.35 0.55 roughness 0.2 } geometry Box { size 0.45 0.05 0.30 } }
Solid { translation 15 1.85 1.12 children [ USE MONITOR ] name "mon_a1" }
Solid { translation 18 1.85 1.12 children [ USE MONITOR ] name "mon_a2" }
Solid { translation 21 1.85 1.12 children [ USE MONITOR ] name "mon_a3" }

# Toolboxes on benches
