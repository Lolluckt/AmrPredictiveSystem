Solid { translation 28.3 0.9 0.65 children [ USE GAS_CYL ] name "gas_2" boundingObject Cylinder { height 1.3 radius 0.15 } }
Solid { translation 30.8 0.9 0.65 children [ USE GAS_CYL ] name "gas_3" boundingObject Cylinder { height 1.3 radius 0.15 } }

# Welding sparks — emissive sphere
