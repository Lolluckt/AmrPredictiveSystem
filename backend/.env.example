# Runtime configuration (copy to .env and adjust)
APP_NAME="AMR Predictive Maintenance API"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://amr:amr@localhost:5432/amr_pdm

# JWT
JWT_SECRET=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MQTT
MQTT_ENABLED=true
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_PATTERN=factory/+/+/telemetry/#
